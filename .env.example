# ============================================================
# Mini Agent 配置文件
# 将此文件复制为 .env 并填入你的配置
# ============================================================

# === OpenAI API 配置 ===
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === 会话 Token 限额配置 ===
# 整个会话的累计 token 上限（包括 LLM 推理 + 工具结果的总和）
# 设为 0 表示不限制。超过此值时，Agent 会自动压缩早期对话。
# 这是"用户交互总token"的限制——一次会话中所有 LLM 调用和工具返回的总量。
TOTAL_TOKEN_LIMIT=0

# 每次 LLM API 调用的 max_tokens 参数
# 控制模型每次回复的最大 token 数，防止单次回复占用过多 token
# 设为 0 表示不限制
DEFAULT_LLM_MAX_TOKENS=4096

# 是否启用 token 限额检查（true=启用, false=禁用）
ENABLE_TOKEN_LIMIT=true

# 超限时是否在工具结果中打印截断警告
TOKEN_TRUNCATE_WARN=true

# === 工具级别配额（代码级配置，非环境变量）===
# 每个工具可以在其实现中设置 quota_limit 属性，控制该工具
# 在单次会话中的 token 消耗上限。默认 0 = 不限额，仅统计使用量。
# 已在以下工具中预置了示例配额：
#   - calculator: 500 tokens
#   - search: 2000 tokens
#   - read_file: 5000 tokens
# 修改工具文件中的 quota_limit 属性值即可调整。

# === 工具执行配置 ===
# LLM API 请求超时秒数
LLM_TIMEOUT=60

# 工具执行失败时的最大重试次数（0=不重试）
MAX_TOOL_RETRIES=2

# 工具重试间隔秒数
TOOL_RETRY_DELAY=1.0
